APP_NAME=GestioDia
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://gestiodia.example.com
APP_TIMEZONE=Europe/Madrid

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_ES

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=error

# Hostinger compartido: driver nd_pdo_mysql, sin exec()/shell_exec(), sin daemon de colas.
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

# Sin proceso daemon disponible en Hostinger: todo síncrono (colas) o vía cron (tasks:generate-daily, photos:prune).
SESSION_DRIVER=file
QUEUE_CONNECTION=sync
CACHE_STORE=file

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public

# SMTP de Hostinger (Mail de Laravel, no Nodemailer).
MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=no-reply@gestiodia.example.com
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
